              <footer/>
            </default-template>
          </layout-master>
          <layout-master name="c" page-width="15" page-height="5" duplex="true">
            <default-template>
              <header>
                <field>
                  <string value=""/>
                </field>
                <field>
                  <current-page number-format="default"/>

            <default-template>
              <header/>
              <footer/>
            </default-template>
          </layout-master>
          <volume-template use-when="(! (= $volume 1))" sheets-in-volume-max="1000"/>
          <volume-template use-when="(= $volume 1)" sheets-in-volume-max="1000">

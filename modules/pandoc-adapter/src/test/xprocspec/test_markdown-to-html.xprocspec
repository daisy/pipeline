<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.daisy.org/ns/xprocspec"
               xmlns:px="http://www.daisy.org/ns/pipeline/xproc"
               xmlns:d="http://www.daisy.org/ns/pipeline/data"
               xmlns:c="http://www.w3.org/ns/xproc-step"
               xmlns:h="http://www.w3.org/1999/xhtml"
               script="../../main/resources/xml/library.xpl">

  <x:scenario label="test">
    <x:call step="px:pandoc-markdown-to-html">
      <x:input port="source.fileset">
        <x:document type="inline">
          <d:fileset>
            <d:file href="index.md" media-type="text/markdown"/>
            <d:file href="image.png" media-type="image/png" original-href="../resources/image.png"/>
          </d:fileset>
        </x:document>
      </x:input>
      <x:input port="source.in-memory">
        <x:document type="inline" xml:space="preserve" xml:base="index.md">
          <c:data content-type="text/plain">
# headline

paragraph with ![image](image.png)
</c:data>
        </x:document>
      </x:input>
      <x:option name="result-dir" select="resolve-uri('result/')"/>
    </x:call>
    <x:context label="result.fileset">
      <x:document type="port" port="result.fileset"/>
    </x:context>
    <x:expect label="result.fileset port" type="custom"
              href="http://www.daisy.org/pipeline/modules/fileset-utils/library.xpl" step="x:fileset-compare">
      <x:document type="inline">
        <d:fileset>
          <d:file href="result/index.html" media-type="application/xhtml+xml"/>
          <d:file href="result/image.png" media-type="image/png" kind="image" original-href="../resources/image.png"/>
        </d:fileset>
      </x:document>
    </x:expect>
    <x:context label="result.in-memory">
      <x:document type="port" port="result.in-memory" select="//h:body"/>
    </x:context>
    <x:expect label="html" type="compare">
      <x:document type="inline" xmlns="http://www.w3.org/1999/xhtml">
        <body>
          <h1 id="headline">headline</h1>
          <p>paragraph with <img src="image.png" alt="image"/></p>
        </body>
      </x:document>
    </x:expect>
  </x:scenario>

</x:description>
